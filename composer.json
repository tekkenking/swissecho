{
    "name": "tekkenking/swissecho",
    "description": "A multigateway laravel SMS notification channel package",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Tekkenking\\Swissecho\\": "src/"
        },
        "files": [
            "src/SwissechoHelpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tekkenking\\Swissecho\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Temitayo",
            "email": "bucketcodes@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/notifications": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/queue": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/broadcasting": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/mail": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/log": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tekkenking\\Swissecho\\SwissechoServiceProvider"
            ],
            "aliases": {
                "Swissecho": "Tekkenking\\Swissecho\\SwissechoFacade"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
